rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. 유저 프로필
    match /users/{userId} {
      allow read: if true; // 외부 공유 페이지에서 닉네임 렌더링을 위해 read 허용
      allow create: if request.auth != null && request.auth.uid == userId;
      // 본인이 수정하거나, 친구 수락 시 상대방이 내 friends 리스트에 자신을 추가할 수 있도록 허용
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
      );
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // 친구 요청
      match /friend_requests/{requestId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
      
      // 알림
      match /notifications/{notiId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // 2. 옷장: 누구나 읽을 수 있지만(비로그인 외부 공유 포함), 생성/수정/삭제는 본인만 가능
    match /clothes/{clothId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 3. OOTD
    match /ootds/{ootdId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null; 
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // 댓글
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // 4. 코디 아이디어 (Planned OOTDs)
    match /planned_ootds/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null; 
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // 5. 예비 OOTD 폴더 (Planned Folders)
    match /planned_folders/{folderId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 6. 옷장 폴더 (Closet Folders)
    match /closet_folders/{folderId} {
      allow read: if true; // 외부 공유 페이지 및 친구 쇼룸을 위해 전체 리드 개방
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 7. 일반 아이템 폴더 (Item Folders)
    match /item_folders/{folderId} {
      allow read: if true; // 외부 공유 페이지 및 친구 쇼룸을 위해 전체 리드 개방
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 8. 일반 아이템 (Items)
    match /items/{itemId} {
      allow read: if true; // 외부 공유 페이지 및 친구 쇼룸을 위해 전체 리드 개방
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}

